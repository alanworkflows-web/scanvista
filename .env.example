# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PADDLE_API_KEY: Paddle API Key
PADDLE_API_KEY="pdl_live_apikey_..."

# PADDLE_SECRET_KEY: Paddle Secret Key for Webhooks
PADDLE_SECRET_KEY="your_paddle_sandbox_secret"

# VITE_PADDLE_CLIENT_TOKEN: Paddle Client Token for frontend
VITE_PADDLE_CLIENT_TOKEN="test_token_..."

# Authentication
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"
SESSION_SECRET="your_secure_session_secret"

# Database
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"
